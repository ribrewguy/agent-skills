# Workspace data is published under skills/*-workspace/ for transparency on
# eval results. To suppress local re-runs from being committed, uncomment:
# skills/*-workspace/

# OS / editor
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Python (for any scripts that may ship alongside skills)
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Node (same rationale)
node_modules/
npm-debug.log
yarn-error.log
